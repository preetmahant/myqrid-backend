NODE_ENV=development

PORT=3000

DATABASE_URL=postgresql://myqrid:myqrid@localhost:5432/myqrid?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=myqrid_access_secret_key_2024_secure_random
JWT_REFRESH_SECRET=myqrid_refresh_secret_key_2024_secure_random

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGINS=[http://localhost:3000,http://localhost:5173](http://localhost:3000,http://localhost:5173)

API_BASE_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

BCRYPT_ROUNDS=12

LOG_LEVEL=info

UPLOAD_PROVIDER=local

MAX_FILE_SIZE=10485760

PRISMA_LOG_LEVEL=query,error,warn

ENABLE_SWAGGER=true

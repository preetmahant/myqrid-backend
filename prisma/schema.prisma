generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PremiumStatus { free premium pro enterprise }
enum TagStatus { active inactive lost found emergency suspended }
enum TagVisibility { public private protected }
enum TagType { personal business asset pet safety medical helmet luggage kid vehicle event creator employee enterprise }
enum TagMode { normal lost emergency business maintenance event }
enum InventoryWarehouseStatus { manufactured in_stock reserved shipped delivered damaged returned }
enum InventoryActivationStatus { not_activated assigned activated deactivated suspended }
enum ShipmentStatus { not_shipped packed shipped in_transit delivered returned }
enum PaymentStatus { pending paid failed refunded cancelled }
enum PaymentMethod { online cod wallet free }
enum CodStatus { not_applicable pending collected remitted failed }
enum SubscriptionStatus { trial active past_due cancelled expired suspended }
enum BillingCycle { monthly yearly lifetime }
enum ScanAction { scan click share save call whatsapp download nfc_tap ble_ping }
enum LostFoundStatus { lost reported found recovered closed }
enum AlertStatus { open acknowledged resolved false_alarm }
enum NotificationChannel { push email sms whatsapp in_app }
enum NotificationStatus { queued sent failed read }
enum FileVisibility { private public protected }
enum ApiKeyStatus { active revoked expired }

model Tenant {
  id        BigInt    @id @default(autoincrement())
  uuid      String    @unique @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  plan      String    @default("free")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users             User[]
  tags              Tag[]
  products          Product[]
  orders            Order[]
  tagInventory      TagInventory[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]
  affiliatePartners AffiliatePartner[]

  @@map("tenants")
}

model User {
  id            BigInt        @id @default(autoincrement())
  uuid          String        @unique @default(uuid()) @db.Uuid
  tenantId      BigInt        @map("tenant_id")
  username      String        @unique
  email         String?       @unique
  phone         String?       @unique
  passwordHash  String?       @map("password_hash")
  avatar        String?
  bio           String?
  roleId        BigInt        @map("role_id")
  premiumStatus PremiumStatus @default(free) @map("premium_status")
  premiumExpiry DateTime?     @map("premium_expiry")
  referralCode  String?       @unique @map("referral_code")
  walletBalance Decimal       @default(0) @map("wallet_balance") @db.Decimal(12, 2)
  isVerified    Boolean       @default(false) @map("is_verified")
  isActive      Boolean       @default(true) @map("is_active")
  lastLogin     DateTime?     @map("last_login")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  role               Role                @relation(fields: [roleId], references: [id])
  sessions           UserSession[]
  otpCodes           OtpCode[]
  tags               Tag[]               @relation("TagOwner")
  inventory          TagInventory[]      @relation("InventoryVendor")
  orders             Order[]
  subscriptions      Subscription[]
  scanLogs           ScanLog[]           @relation("Scanner")
  lostReports        LostAndFound[]      @relation("LostReporter")
  files              File[]
  notifications      Notification[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  activityLogs       ActivityLog[]
  emergencyContacts  EmergencyContact[]
  businessProfiles   BusinessProfile[]
  enterpriseAccounts EnterpriseAccount[]

  @@index([tenantId])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          BigInt           @id @default(autoincrement())
  roleName    String           @unique @map("role_name")
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             BigInt           @id @default(autoincrement())
  permissionName String           @unique @map("permission_name")
  description    String?
  createdAt      DateTime         @default(now()) @map("created_at")
  roles          RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")
  role         Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserSession {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  refreshToken String    @unique @map("refresh_token")
  deviceId     String?   @map("device_id")
  deviceName   String?   @map("device_name")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model OtpCode {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt?   @map("user_id")
  channel   String
  target    String
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([target])
  @@map("otp_codes")
}

model Tag {
  id                  BigInt        @id @default(autoincrement())
  uuid                String        @unique @default(uuid()) @db.Uuid
  tenantId            BigInt        @map("tenant_id")
  uniqueSlug          String        @unique @map("unique_slug")
  qrCodeUrl           String        @map("qr_code_url")
  shortUrl            String?       @map("short_url")
  nfcUid              String?       @unique @map("nfc_uid")
  bleDeviceId         String?       @unique @map("ble_device_id")
  ownerUserId         BigInt?       @map("owner_user_id")
  tagType             TagType       @map("tag_type")
  tagSubtype          String?       @map("tag_subtype")
  status              TagStatus     @default(inactive)
  visibility          TagVisibility @default(public)
  premiumEnabled      Boolean       @default(false) @map("premium_enabled")
  activationDate      DateTime?     @map("activation_date")
  expiryDate          DateTime?     @map("expiry_date")
  lastScanAt          DateTime?     @map("last_scan_at")
  scanCount           Int           @default(0) @map("scan_count")
  isTransferable      Boolean       @default(true) @map("is_transferable")
  ownershipVerified   Boolean       @default(false) @map("ownership_verified")
  currentMode         TagMode       @default(normal) @map("current_mode")
  metadata            Json          @default("{}")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  owner           User?              @relation("TagOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  deviceMappings  DeviceMapping[]
  scanLogs        ScanLog[]
  lostAndFound    LostAndFound[]
  emergencyAlerts EmergencyAlert[]
  vehicleProfile  VehicleProfile?
  petProfile      PetProfile?
  assetProfile    AssetProfile?
  businessProfile BusinessProfile?
  orderItems      OrderItem[]

  @@index([tenantId, tagType, status])
  @@index([ownerUserId])
  @@index([deletedAt])
  @@map("tags")
}

model TagTypeCustomization {
  id               BigInt  @id @default(autoincrement())
  tagType          TagType @unique @map("tag_type")
  allowedModules   Json    @map("allowed_modules")
  premiumModules   Json    @map("premium_modules")
  allowedFields    Json    @map("allowed_fields")
  hiddenFields     Json    @map("hidden_fields")
  allowedThemes    Json    @map("allowed_themes")
  colorPacks       Json    @map("color_packs")
  iconPacks        Json    @map("icon_packs")
  animationSupport Boolean @default(false) @map("animation_support")
  dynamicModes     Json    @map("dynamic_modes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("tag_type_customizations")
}

model ProfileModule {
  id             BigInt   @id @default(autoincrement())
  moduleKey       String   @unique @map("module_key")
  title           String
  description     String?
  schema          Json     @default("{}")
  isPremium       Boolean  @default(false) @map("is_premium")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("profile_modules")
}

model TagInventory {
  id                 BigInt                    @id @default(autoincrement())
  tenantId           BigInt                    @map("tenant_id")
  batchNumber        String                    @map("batch_number")
  qrCode             String                    @unique @map("qr_code")
  nfcUid             String?                   @unique @map("nfc_uid")
  bleDeviceId        String?                   @unique @map("ble_device_id")
  manufacturingDate  DateTime                  @default(now()) @map("manufacturing_date")
  vendorId           BigInt?                   @map("vendor_id")
  warehouseStatus    InventoryWarehouseStatus  @default(manufactured) @map("warehouse_status")
  activationStatus   InventoryActivationStatus @default(not_activated) @map("activation_status")
  shipmentStatus     ShipmentStatus            @default(not_shipped) @map("shipment_status")
  serialNumber       String                    @unique @map("serial_number")
  warehouseLocation  String?                   @map("warehouse_location")
  metadata           Json                      @default("{}")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  deletedAt          DateTime?                 @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor User?  @relation("InventoryVendor", fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId, batchNumber])
  @@index([warehouseStatus, activationStatus])
  @@map("tag_inventory")
}

model Product {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique @default(uuid()) @db.Uuid
  tenantId    BigInt    @map("tenant_id")
  sku         String    @unique
  title       String
  description String?
  category    String
  price       Decimal   @db.Decimal(12, 2)
  gstRate     Decimal   @default(18) @map("gst_rate") @db.Decimal(5, 2)
  stockQty    Int       @default(0) @map("stock_qty")
  isActive    Boolean   @default(true) @map("is_active")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  orderItems OrderItem[]

  @@index([tenantId, category])
  @@map("products")
}

model Order {
  id              BigInt        @id @default(autoincrement())
  tenantId        BigInt        @map("tenant_id")
  orderNumber     String        @unique @map("order_number")
  userId          BigInt        @map("user_id")
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  gstAmount       Decimal       @default(0) @map("gst_amount") @db.Decimal(12, 2)
  shippingCharge  Decimal       @default(0) @map("shipping_charge") @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  paymentMethod   PaymentMethod @default(online) @map("payment_method")
  codStatus       CodStatus     @default(not_applicable) @map("cod_status")
  invoicePdf      String?       @map("invoice_pdf")
  shippingAddress Json          @map("shipping_address")
  courierPartner  String?       @map("courier_partner")
  trackingId      String?       @map("tracking_id")
  deliveredAt     DateTime?     @map("delivered_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  user   User        @relation(fields: [userId], references: [id])
  items  OrderItem[]

  @@index([tenantId, userId])
  @@index([paymentStatus, createdAt])
  @@map("orders")
}

model OrderItem {
  id        BigInt   @id @default(autoincrement())
  orderId   BigInt   @map("order_id")
  productId BigInt?  @map("product_id")
  tagId     BigInt?  @map("tag_id")
  title     String
  quantity  Int      @default(1)
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  gstAmount Decimal  @default(0) @map("gst_amount") @db.Decimal(12, 2)
  metadata  Json     @default("{}")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  tag     Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Subscription {
  id                 BigInt             @id @default(autoincrement())
  userId             BigInt             @map("user_id")
  planName           PremiumStatus      @map("plan_name")
  billingCycle       BillingCycle       @map("billing_cycle")
  amount             Decimal            @db.Decimal(12, 2)
  featuresEnabled    Json               @map("features_enabled")
  renewalDate        DateTime?          @map("renewal_date")
  subscriptionStatus SubscriptionStatus @default(active) @map("subscription_status")
  autoRenew          Boolean            @default(false) @map("auto_renew")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  cancelledAt        DateTime?          @map("cancelled_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subscriptionStatus])
  @@map("subscriptions")
}

model PremiumFeature {
  id          BigInt   @id @default(autoincrement())
  featureKey  String   @unique @map("feature_key")
  title       String
  description String?
  tier        PremiumStatus
  config      Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("premium_features")
}

model DeviceMapping {
  id          BigInt    @id @default(autoincrement())
  tagId       BigInt?   @map("tag_id")
  nfcUid      String?   @unique @map("nfc_uid")
  bleDeviceId String?   @unique @map("ble_device_id")
  deviceType  String    @map("device_type")
  hardwareSku String?   @map("hardware_sku")
  isActive    Boolean   @default(true) @map("is_active")
  pairedAt    DateTime? @map("paired_at")
  lastSeenAt  DateTime? @map("last_seen_at")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tag Tag? @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@index([deviceType, isActive])
  @@map("device_mappings")
}

model ScanLog {
  id           BigInt     @id @default(autoincrement())
  tagId        BigInt     @map("tag_id")
  scannerUserId BigInt?   @map("scanner_user_id")
  scannerIp    String?    @map("scanner_ip")
  gpsLatitude  Decimal?   @map("gps_latitude") @db.Decimal(10, 7)
  gpsLongitude Decimal?   @map("gps_longitude") @db.Decimal(10, 7)
  city         String?
  region       String?
  country      String?
  browser      String?
  os           String?
  deviceType   String?    @map("device_type")
  scanAction   ScanAction @default(scan) @map("scan_action")
  duration     Int?
  referrer     String?
  suspiciousScore Int     @default(0) @map("suspicious_score")
  anomalyFlags Json       @default("[]") @map("anomaly_flags")
  metadata     Json       @default("{}")
  timestamp    DateTime   @default(now())

  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  scanner User? @relation("Scanner", fields: [scannerUserId], references: [id], onDelete: SetNull)

  @@index([tagId, timestamp])
  @@index([country, city])
  @@index([scanAction, timestamp])
  @@map("scan_logs")
}

model LostAndFound {
  id           BigInt          @id @default(autoincrement())
  tagId        BigInt          @map("tag_id")
  reporterId   BigInt?         @map("reporter_id")
  status       LostFoundStatus @default(lost)
  description  String?
  rewardAmount Decimal?        @map("reward_amount") @db.Decimal(12, 2)
  finderContact Json?          @map("finder_contact")
  timeline     Json            @default("[]")
  recoveredAt  DateTime?       @map("recovered_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tag      Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  reporter User? @relation("LostReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@map("lost_and_found")
}

model EmergencyAlert {
  id          BigInt      @id @default(autoincrement())
  tagId       BigInt      @map("tag_id")
  status      AlertStatus @default(open)
  bloodGroup  String?     @map("blood_group")
  allergies   Json        @default("[]")
  contacts    Json        @default("[]")
  location    Json?       
  message     String?
  createdAt   DateTime    @default(now()) @map("created_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  resolvedAt  DateTime?   @map("resolved_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("emergency_alerts")
}

model EmergencyContact {
  id        BigInt  @id @default(autoincrement())
  userId    BigInt  @map("user_id")
  name      String
  phone     String
  relation  String?
  priority  Int     @default(1)
  isActive  Boolean @default(true) @map("is_active")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

model VehicleProfile {
  id             BigInt   @id @default(autoincrement())
  tagId          BigInt   @unique @map("tag_id")
  rcNumber       String?  @map("rc_number")
  insurance      Json?   
  fastag          Json?
  serviceRecords Json     @default("[]") @map("service_records")
  towingContacts Json     @default("[]") @map("towing_contacts")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  tag            Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("vehicle_profiles")
}

model PetProfile {
  id          BigInt   @id @default(autoincrement())
  tagId       BigInt   @unique @map("tag_id")
  breed       String?
  vaccination Json     @default("[]")
  vetInfo     Json?    @map("vet_info")
  allergies   Json     @default("[]")
  reward      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("pet_profiles")
}

model AssetProfile {
  id              BigInt   @id @default(autoincrement())
  tagId           BigInt   @unique @map("tag_id")
  serialNumber    String?  @map("serial_number")
  invoiceFileId   BigInt?  @map("invoice_file_id")
  warranty        Json?
  ownershipProof  Json?    @map("ownership_proof")
  maintenanceLogs Json     @default("[]") @map("maintenance_logs")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tag             Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("asset_profiles")
}

model BusinessProfile {
  id          BigInt   @id @default(autoincrement())
  tagId       BigInt?  @unique @map("tag_id")
  userId      BigInt?  @map("user_id")
  companyName String   @map("company_name")
  gstNumber   String?  @map("gst_number")
  socialLinks Json     @default("{}") @map("social_links")
  products    Json     @default("[]")
  leadForms   Json     @default("[]") @map("lead_forms")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tag         Tag?     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("business_profiles")
}

model File {
  id           BigInt         @id @default(autoincrement())
  uuid         String         @unique @default(uuid()) @db.Uuid
  ownerUserId  BigInt?        @map("owner_user_id")
  fileName     String         @map("file_name")
  mimeType     String         @map("mime_type")
  sizeBytes    BigInt         @map("size_bytes")
  storageKey   String         @map("storage_key")
  publicUrl    String?        @map("public_url")
  visibility   FileVisibility @default(private)
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  deletedAt    DateTime?      @map("deleted_at")
  owner        User?          @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@map("files")
}

model Notification {
  id        BigInt              @id @default(autoincrement())
  userId    BigInt?             @map("user_id")
  channel   NotificationChannel
  status    NotificationStatus  @default(queued)
  title     String
  body      String
  payload   Json                @default("{}")
  sentAt    DateTime?           @map("sent_at")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("notifications")
}

model ApiKey {
  id          BigInt       @id @default(autoincrement())
  tenantId    BigInt       @map("tenant_id")
  keyHash     String       @unique @map("key_hash")
  name        String
  scopes      Json         @default("[]")
  status      ApiKeyStatus @default(active)
  lastUsedAt  DateTime?    @map("last_used_at")
  expiresAt   DateTime?    @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  revokedAt   DateTime?    @map("revoked_at")
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt?  @map("tenant_id")
  actorUserId BigInt?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ActivityLog {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt?  @map("tenant_id")
  userId    BigInt?  @map("user_id")
  activity  String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model AffiliatePartner {
  id                BigInt   @id @default(autoincrement())
  tenantId          BigInt   @map("tenant_id")
  name              String
  email             String?
  commissionPercent Decimal  @default(0) @map("commission_percent") @db.Decimal(5, 2)
  payoutConfig      Json     @default("{}") @map("payout_config")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("affiliate_partners")
}

model EnterpriseAccount {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  company   String
  seats     Int      @default(1)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("enterprise_accounts")
}
